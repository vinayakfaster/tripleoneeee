// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  name              String?
  email             String?       @unique
  emailVerified     DateTime?
  bio               String?
  image             String?
  hashedPassword    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime?     @updatedAt
  role              String        @default("user")
  favoriteIds       String[]      @db.ObjectId
  accounts          Account[]
  listings          Listing[]
  reservations      Reservation[]
  reviews           Review[]
  phone             String? // ✅ optional phone number
  contactPhone      String?
  razorpayAccountId String? // For 'host' payouts only
  payouts           Payout[]
  enquiries         Enquiry[]
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Listing {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String
  imageSrc       Json[]
  createdAt      DateTime      @default(now())
  category       String
  roomCount      Int
  bathroomCount  Int
  guestCount     Int
  locationValue  String
  userId         String        @db.ObjectId
  price          Int
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations   Reservation[]
  reviews        Review[]
  contactPhone   String?
  updatedAt      DateTime?     @updatedAt
  lastModifiedBy String?
  enquiries      Enquiry[] // ✅ ADD THIS
  isBestSeller Boolean @default(false)
}

model Reservation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  listingId   String   @db.ObjectId
  startDate   DateTime
  endDate     DateTime
  totalPrice  Int
  guestCount  Int
  guests      Json? // Detailed guest object
  paymentId   String? // Razorpay ID
  bookedName  String? // ✅ New: Store name at time of booking
  bookedPhone String? // ✅ New: Store phone at time of booking
  bookedEmail String? // ✅ Optional: snapshot email
  reviewId    String?  @db.ObjectId // Optional reference to Review

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviews   Review[]
}

model Review {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  listingId     String
  listing       Listing     @relation(fields: [listingId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  rating        Int
  comment       String
  createdAt     DateTime    @default(now())
}

model Payout {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  payoutId String  @unique
  amount   Float
  currency String
  status   String
  notes    Json?
  userId   String? @db.ObjectId
  user     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model Enquiry {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId

  listingId     String   @db.ObjectId
  userId        String?  @db.ObjectId

  name          String
  email         String
  phone         String
  message       String?
  guestId   String? 
  listingTitle  String?
  listingImage  String?
  guestCount    Int?
  startDate     DateTime?
  endDate       DateTime?

  // 🔥 ADD THESE (CORE FEATURE)
  status        String   @default("pending") // pending | checked_in | checked_out | rejected
  checkedInAt   DateTime?
  checkedOutAt  DateTime?

  createdAt     DateTime @default(now())

  listing       Listing  @relation(fields: [listingId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])
}